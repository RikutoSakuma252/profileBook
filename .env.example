# Database
# 開発時: SQLite (ローカルファイル)
# 本番時: PostgreSQL (例: "postgresql://user:pass@host:5432/profilebook")
DATABASE_URL="file:./dev.db"

# Auth.js v5 (NextAuth v5)
# 開発時: 不要 / 本番 (Vercel 等) ではデプロイ先 URL を指定
# AUTH_URL="https://xxx.vercel.app"
# openssl rand -base64 32 で生成
AUTH_SECRET="REPLACE_WITH_RANDOM_SECRET"

# Google OAuth (ログイン用 - Google Cloud Console で作成)
# Auth.js v5 は AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET を自動検出する
AUTH_GOOGLE_ID="REPLACE_WITH_CLIENT_ID"
AUTH_GOOGLE_SECRET="REPLACE_WITH_CLIENT_SECRET"

# Google Sheets API (データ取得用 - サービスアカウントの JSON キーを1行に圧縮したもの)
GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"...","client_email":"...@....iam.gserviceaccount.com"}'

# Webhook (Google Apps Script から呼ばれるエンドポイントの認証用)
WEBHOOK_SECRET="REPLACE_WITH_RANDOM_SECRET"

# 許可ドメイン (このドメインのメールアドレスのみログイン可)
ALLOWED_EMAIL_DOMAIN="e3sys.co.jp"
